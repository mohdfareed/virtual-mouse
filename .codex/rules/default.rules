# Allow safe project-local commands without prompting.

prefix_rule(
    pattern = [".\\scripts\\"],
    decision = "allow",
    justification = "Project-local scripts are approved.",
)

prefix_rule(
    pattern = ["git", "status"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "diff"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "log"],
    decision = "allow",
)
