{
  "VirtualMouse": {
    "Viiper": {
      "Host": "host.docker.internal",
      "Port": 3242
    },
    "Steam": {
      "SrmExportPath": ".\\srm-manifest.json"
    },
    "Games": {
      "game-id": {
        "Title": "Game Title",
        "Executable": "C:\\Path\\To\\GameExecutable.exe",
        "Arguments": "--game-arguments",
        "SteamAppId": 123456,
        "WorkingDirectory": "C:\\Path\\To",
        "ControllerOutput": "Xbox360",
        "MouseOutput": "Viiper",
        "ReceiverProcesses": [
          "GameProcess.exe",
          "SubGameProcess.exe"
        ]
      }
    },
    "Logging": {
      "LogDirectory": ".\\logs",
      "Level": "Information"
    }
  }
}
