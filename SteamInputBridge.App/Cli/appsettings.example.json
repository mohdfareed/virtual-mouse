{
  "SteamInputBridge": {
    "Logging": {
      "LogDirectory": "./logs",
      "Level": "Debug"
    },
    "Viiper": {
      "Host": "host.docker.internal",
      "Port": 3242
    },
    "Steam": {
      "SrmExportPath": "./srm-manifest.json"
    },
    "HidHide": {
      "CliPath": "C:/Path/To/HidHide.exe"
    },
    "Shortcuts": [
      {
        "Name": "motion-on",
        "Keys": "Ctrl+Alt+F13",
        "Target": "Motion",
        "Value": "Enabled"
      }
    ],
    "Games": {
      "game-id": {
        "Title": "Game Title",
        "Executable": "C:/Path/To/GameExecutable.exe",
        "Arguments": "--game-arguments",
        "SteamAppId": 123456,
        "WorkingDirectory": "C:/Path/To",
        "ControllerOutput": "Xbox360",
        "MouseOutput": "Viiper",
        "ReceiverProcesses": [
          "GameProcess.exe",
          "SubGameProcess.exe"
        ]
      }
    }
  }
}
